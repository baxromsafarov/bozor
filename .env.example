# Bozor — пример конфигурации окружения (12-factor).
# Скопируй в .env и заполни секреты. НИКОГДА не коммить .env.

# --- PostgreSQL (один инстанс, БД на сервис) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=bozor
POSTGRES_PASSWORD=change-me-strong
# Имена БД по сервисам создаются init-скриптом: bozor_auth, bozor_profile, bozor_catalog,
# bozor_location, bozor_listing, bozor_media, bozor_favorites, bozor_chat,
# bozor_notification, bozor_moderation, bozor_payments, bozor_reviews

# --- PgBouncer ---
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# --- NATS JetStream ---
NATS_URL=nats://nats:4222

# --- Typesense ---
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=change-me-typesense-key

# --- MinIO (S3) ---
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=bozor-minio
MINIO_ROOT_PASSWORD=change-me-minio
MEDIA_BUCKET=bozor-media
MEDIA_PUBLIC_BASE_URL=http://localhost:9000/bozor-media
# Обработка/очистка медиа (Stage 3.2). TTL/интервал — формат time.Duration.
MEDIA_ORPHAN_TTL=24h
MEDIA_CLEAN_INTERVAL=15m
MEDIA_PRESIGN_TTL=15m

# --- Listing: жизненный цикл объявлений (Stage 3.4) ---
LISTING_AD_TTL=720h              # срок активного объявления (30 дней); renew продлевает
LISTING_EXPIRE_INTERVAL=5m       # период воркера истечения по expires_at
LISTING_EXPIRE_BATCH=100         # сколько объявлений истекает за проход
# Счётчик просмотров (Stage 3.5): буфер в Redis, периодический флеш в БД
LISTING_VIEWS_FLUSH_INTERVAL=30s # период слива буфера просмотров в PostgreSQL

# --- Favorites/SavedSearch (Stage 5.3) ---
SAVED_SEARCH_NOTIFY_THROTTLE=1m  # окно троттлинга уведомлений на один сохранённый поиск

# --- Notification (Stage 6.1) ---
# TELEGRAM_BOT_TOKEN см. ниже (общий с Auth). Пустой токен => канал отключён,
# уведомления помечаются skipped(channel_disabled) — удобно без реального бота.
NOTIFY_RATE_PER_SEC=25           # глобальный лимит отправок в Telegram Bot API (шт/сек)
NOTIFY_RATE_BURST=25             # ёмкость token-bucket отправок
NOTIFY_PREFS_CACHE_TTL=30s       # TTL кеша notification_prefs (из User/Profile)
NOTIFY_MAX_DELIVER=5             # попыток доставки события до DLQ

# --- JWT ---
JWT_SIGNING_KEY=change-me-256-bit-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# --- API Gateway ---
GATEWAY_ADDR=:8080
RATE_LIMIT_RPS=20                # пополнение token-bucket, запросов/сек
RATE_LIMIT_BURST=40              # ёмкость bucket'а (всплеск)
CORS_ALLOWED_ORIGINS=*           # список источников через запятую или *
# Апстримы сервисов переопределяются через UPSTREAM_<SERVICE> (по умолчанию http://<service>:8080)

# --- Telegram Bot (Auth + Notifications) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret

# --- Платёжные провайдеры ---
PAYMENTS_PROVIDER=mock          # mock | payme | click
PAYME_MERCHANT_ID=
PAYME_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# --- Наблюдаемость ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# --- Общее ---
APP_ENV=dev                     # dev | prod
LOG_LEVEL=info

# --- Chat ---
CHAT_RATE_PER_SEC=1
CHAT_RATE_BURST=5

# --- Payments/Promotions (провайдеры оплаты; замените на реальные merchant-реквизиты в prod) ---
PAYME_MERCHANT_ID=payme-merchant-dev
PAYME_KEY=payme-key-dev
CLICK_SERVICE_ID=click-service-dev
CLICK_MERCHANT_ID=click-merchant-dev
CLICK_SECRET_KEY=click-secret-dev
PAYMENTS_BUMP_INTERVAL=1m       # период воркера авто-поднятий (Stage 8.5); dev можно уменьшить
