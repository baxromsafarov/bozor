{
  "uid": "bozor-infra-health",
  "title": "Bozor — Infra Health (USE)",
  "tags": ["bozor", "use", "infra"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Scrape targets UP",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{job}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Process CPU (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{job}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(process_cpu_seconds_total[$__rate_interval])"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Process resident memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{job}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Goroutines (gateway)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{job}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_goroutines{job=\"gateway\"}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Scrape duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{job}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scrape_duration_seconds"
        }
      ]
    }
  ]
}
